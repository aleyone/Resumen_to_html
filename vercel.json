{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "admin.html", "use": "@vercel/static" },
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "api/upload.js", "use": "@vercel/node" },
    { "src": "api/deployments.js", "use": "@vercel/node" },
    { "src": "api/delete.js", "use": "@vercel/node" },
    { "src": "api/edit.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/upload", "dest": "/api/upload.js" },
    { "src": "/api/deployments", "dest": "/api/deployments.js" },
    { "src": "/api/delete", "dest": "/api/delete.js" },
    { "src": "/api/edit", "dest": "/api/edit.js" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
